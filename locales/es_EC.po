# --- Tenants Config ---
msgid "Microsoft 365 Tenant Configuration"
msgstr "Configuración de Tenants Microsoft 365"

msgid "Add New Domain/Tenant"
msgstr "Agregar Nuevo Dominio/Tenant"

msgid "Domain"
msgstr "Dominio"

msgid "Tenant ID"
msgstr "ID del Tenant"

msgid "Connection Settings"
msgstr "Ajustes de Conexión"

msgid "Descriptive Name"
msgstr "Nombre Descriptivo"

msgid "Leave empty to keep current secret"
msgstr "Dejar vacío para mantener el secreto actual"

# --- Prefijos y Teams ---
msgid "Default Sync Preferences"
msgstr "Preferencias de Sincronización por Defecto"

msgid "Default Task Prefix"
msgstr "Prefijo de Tarea por Defecto"

msgid "Default Event Prefix"
msgstr "Prefijo de Evento por Defecto"

msgid "Default Teams Status Message"
msgstr "Mensaje de Estado de Teams por Defecto"

# --- User Config ---
msgid "Microsoft 365 Synchronization"
msgstr "Sincronización Microsoft 365"

msgid "Enable Synchronization"
msgstr "Habilitar Sincronización"

msgid "Personalized Prefixes"
msgstr "Prefijos Personalizados"

msgid "Task Prefix"
msgstr "Prefijo de Tarea"

msgid "Event Prefix"
msgstr "Prefijo de Evento"

msgid "Teams Integration"
msgstr "Integración con Teams"

msgid "Personal Status Message"
msgstr "Mensaje de Estado Personalizado"

msgid "Inherit from tenant"
msgstr "Heredar del dominio (tenant)"

msgid "Sync Range Override"
msgstr "Sobrescribir Rango de Sincronización"

msgid "Months in the PAST"
msgstr "Meses hacia el PASADO"

msgid "Months in the FUTURE"
msgstr "Meses hacia el FUTURO"

msgid "If set to 0, it will sync only the last 7 days."
msgstr "Si se establece en 0, solo sincronizará los últimos 7 días."

msgid "If set to 0, it will sync the next 7 days."
msgstr "Si se establece en 0, sincronizará los próximos 7 días."

msgid "If enabled, you can define a custom prefix. If disabled, no prefix will be added."
msgstr "Si está activo, puede definir un prefijo personalizado. Si está desactivado, no se añadirá ningún prefijo."

msgid "If enabled, you can customize the message. If disabled, the default 'Working on:' will be used."
msgstr "Si está activo, puede personalizar el mensaje. Si está desactivado, se usará el valor por defecto 'Trabajando en:'."

msgid "Select 'Yes' to customize, 'No' to disable, or 'Inherit' to use the Tenant settings."
msgstr "Seleccione 'Sí' para personalizar, 'No' para desactivar o 'Heredar' para usar la configuración global."